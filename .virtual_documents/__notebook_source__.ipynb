    if not img_paths:
        print(f"Image not found: {img_dir}")
        return

    dice_list = []
    iou_list = []

    model.eval()
    
    for img_path in tqdm(img_paths, desc="TTA Computing", leave=False):
        try:
            image = Image.open(img_path).convert("RGB")
            original_w, original_h = image.size 
            image = image.resize((Config.IMG_SIZE, Config.IMG_SIZE))
            
            img_np = np.array(image).astype(np.float32) / 255.0
            mean = np.array([0.485, 0.456, 0.406], dtype=np.float32)
            std = np.array([0.229, 0.224, 0.225], dtype=np.float32)
            img_norm = (img_np - mean) / std
            img_tensor = torch.tensor(img_norm).permute(2, 0, 1).unsqueeze(0).float().to(device)
            
            base_name = os.path.basename(img_path)
            name_no_ext = os.path.splitext(base_name)[0]
            mask_path = None
            for ext in ['.png', '.jpg', '.jpeg', '.tif']:
                candidate = os.path.join(mask_dir, name_no_ext + ext)
                if os.path.exists(candidate):
                    mask_path = candidate
                    break
            if not mask_path: 
                candidate = os.path.join(mask_dir, base_name)
                if os.path.exists(candidate): mask_path = candidate
            
            if not mask_path: continue

            mask_gt = Image.open(mask_path).convert("L")
            mask_np = np.array(mask_gt).astype(np.float32) / 255.0
            mask_tensor = torch.tensor(mask_np > 0.5).float().to(device)

            with torch.no_grad():
            
                pred = predict_with_tta(model, img_tensor)
         
                pred = F.interpolate(pred, size=(original_h, original_w), mode='bilinear', align_corners=False)
                pred = torch.sigmoid(pred).squeeze()

            d, i = calculate_metrics_simple(pred, mask_tensor)
            dice_list.append(d)
            iou_list.append(i)
            save_detailed_log(dataset_name, base_name, d, i)
            
        except Exception as e:
            print(f"Error: {e}")
            continue

    if dice_list:
        mean_dice = np.mean(dice_list)
        mean_iou = np.mean(iou_list)
        print(f"\n🏆 [{dataset_name} + TTA] Final Result:")
        print(f"   Mean Dice: {mean_dice:.4f}")
        print(f"   Mean IoU : {mean_iou:.4f}")
        save_final_log(dataset_name, mean_dice, mean_iou)
    else:
        print(f"{dataset_name} No valid results")
    print("-" * 30)

if __name__ == "__main__":

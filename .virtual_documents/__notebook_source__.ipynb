    state_dict = torch.load(weights_path, map_location=device)
    model.load_state_dict(state_dict)
    print(f"✅ 成功复活！加载了之前训练的权重: {weights_path}")
else:
    print("❌ 坏了，权重文件找不到了...")

def save_visual_sample(model, img_dir, mask_dir, dataset_name, save_dir):
    os.makedirs(save_dir, exist_ok=True)
    img_paths = sorted(glob.glob(os.path.join(img_dir, "*")))
    img_paths = [p for p in img_paths if p.lower().endswith(('.png', '.jpg', '.jpeg', '.tif', '.bmp'))]
    
    if not img_paths: return

    samples = random.sample(img_paths, min(len(img_paths), 3))
    model.eval()
    
    print(f"🖼️ 正在为 {dataset_name} 生成展示图...")

    for i, img_path in enumerate(samples):
        try:
            # 读取
            image = Image.open(img_path).convert("RGB")
            w, h = image.size
            
            # 预处理
            img_resized = image.resize((Config.IMG_SIZE, Config.IMG_SIZE))
            img_np = np.array(img_resized).astype(np.float32) / 255.0
            norm = (img_np - [0.485, 0.456, 0.406]) / [0.229, 0.224, 0.225]
            img_tensor = torch.tensor(norm).permute(2, 0, 1).unsqueeze(0).float().to(device)
            
            # 推理
            with torch.no_grad():
                pred = model(img_tensor)
                pred = F.interpolate(pred, size=(h, w), mode='bilinear', align_corners=False)
                pred = torch.sigmoid(pred).squeeze().cpu().numpy()
            
            # 找 GT
            base = os.path.basename(img_path)
            name = os.path.splitext(base)[0]
            mask_path = None
            for ext in ['.png', '.jpg', '.tif']:
                c = os.path.join(mask_dir, name + ext)
                if os.path.exists(c): mask_path = c; break
            if not mask_path: mask_path = os.path.join(mask_dir, base)
            
            if mask_path and os.path.exists(mask_path):
                mask_gt = np.array(Image.open(mask_path).convert("L")) / 255.0
            else:
                mask_gt = np.zeros((h, w))

            # 画图
            fig, ax = plt.subplots(1, 3, figsize=(12, 4))
            ax[0].imshow(image); ax[0].set_title("Input")
            ax[1].imshow(mask_gt, cmap='gray'); ax[1].set_title("GT")
            ax[2].imshow(image)
            ax[2].imshow(pred > 0.5, cmap='spring', alpha=0.6) # 换个颜色
            ax[2].set_title(f"Prediction")
            
            plt.savefig(os.path.join(save_dir, f"{dataset_name}_{i}.png"), bbox_inches='tight')
            plt.close()
            
        except Exception as e:
            print(f"Error: {e}")
            continue
    print(f"✅ 完成！请查看 {save_dir} 文件夹")

# 运行
save_root = "./final_visuals_fixed"
datasets = [
    {"name": "CVC-ColonDB", "img": "/kaggle/input/cvc-colondb/CVC-ColonDB/images", "mask": "/kaggle/input/cvc-colondb/CVC-ColonDB/masks"},
    {"name": "ETIS-Larib",  "img": "/kaggle/input/etis-laribpolypdb/images",        "mask": "/kaggle/input/etis-laribpolypdb/masks"}
]

for ds in datasets:
    if os.path.exists(ds['img']):
        save_visual_sample(model, ds['img'], ds['mask'], ds['name'], save_root)



